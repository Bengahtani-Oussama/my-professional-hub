# ============================================================
# Frontend build secrets — set these in Lovable
# (Workspace Settings → Build Secrets) for production,
# or copy to a local `.env` file for local dev.
# ============================================================

# Base URL of your deployed Express + MongoDB API.
# When unset, the frontend falls back to in-browser mock data.
VITE_API_BASE_URL=http://localhost:4000

# Cloudinary (for CV / image uploads from the admin panel).
# Create an "Unsigned" upload preset in your Cloudinary dashboard.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset